# QuickBid - manual local combinado actualizado
#
# Archivo monolítico generado a partir de los escenarios separados.
# Recomendación: usar preferentemente los archivos 00..99 por grupos.
# Ver README_PRUEBAS_HTTP.md para reset de BD entre ciclos.



# =============================================================================
# 00_smoke_readonly.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 00 smoke readonly / seguro para ejecutar muchas veces
# -----------------------------------------------------------------------------
# Requiere backend levantado con APP_ADMIN_ENABLED=true y
# APP_ADMIN_INTERNAL_KEY=test-admin-key.
# No modifica datos salvo login/refresh/recuperación.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaAprobadaId = 3001
@cuentaMultaId = 3002
@cuentaConsignadorId = 3004
@medioPagoAprobadoArsId = 5001
@medioPagoMultaArsId = 5004
@medioPagoConsignadorArsId = 5005
@subastaEnVivoId = 6001
@subastaEspecialUsdId = 6002
@subastaCerradaId = 6003
@itemActivoId = 9001
@compraMultaId = 13001
@compraPagosExtraId = 13002
@consignacionPendienteId = 16001
@consignacionLiquidadaId = 16007

@accessAprobado = {{loginAprobado.response.body.$.data.accessToken}}
@refreshAprobado = {{loginAprobado.response.body.$.data.refreshToken}}
@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}
@accessMulta = {{loginMulta.response.body.$.data.accessToken}}
@accessBloqueado = {{loginBloqueado.response.body.$.data.accessToken}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Auth - Login usuario aprobado
# @name loginAprobado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "aprobado@quickbid.demo",
  "clave": "Demo123!"
}

### 02 - Auth - Login usuario consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "consignador@quickbid.demo",
  "clave": "Demo123!"
}

### 03 - Auth - Login usuario con restriccion por multa
# @name loginMulta
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "multa@quickbid.demo",
  "clave": "Demo123!"
}

### 04 - Auth - Login usuario bloqueado: ahora es login limitado, no 403
# @name loginBloqueado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "bloqueado@quickbid.demo",
  "clave": "Demo123!"
}

### 05 - Auth - Sesion actual aprobado
GET {{baseUrl}}/api/auth/sesion
Authorization: Bearer {{accessAprobado}}

### 06 - Auth - Endpoint normal con bloqueado debe quedar bloqueado
# Esperado: 403 ACCOUNT_BLOCKED, aunque el login limitado haya devuelto token.
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessBloqueado}}

### 07 - Auth - Refresh usuario aprobado
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshAprobado}}"
}

### 08 - Auth - Solicitar recuperacion de clave
POST {{baseUrl}}/api/auth/recuperar-clave
Content-Type: application/json

{
  "email": "aprobado@quickbid.demo"
}

### 09 - Usuario - Perfil aprobado
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessAprobado}}

### 10 - Usuario - Estadisticas total
GET {{baseUrl}}/api/usuario/estadisticas?periodo=total
Authorization: Bearer {{accessAprobado}}

### 11 - Usuario - Estadisticas mes
GET {{baseUrl}}/api/usuario/estadisticas?periodo=mes
Authorization: Bearer {{accessAprobado}}

### 12 - Usuario - Historial paginado
GET {{baseUrl}}/api/usuario/historial?page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 13 - Usuario - Notificaciones no leidas
GET {{baseUrl}}/api/usuario/notificaciones?leida=false&page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 14 - Usuario - Notificaciones por categoria/tipo
GET {{baseUrl}}/api/usuario/notificaciones?categoria=subasta&page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 15 - Usuario - Direcciones multiples
GET {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}

### 16 - Usuario - Direccion legacy compatible
GET {{baseUrl}}/api/usuario/direccion-envio
Authorization: Bearer {{accessAprobado}}

### 17 - Medios de pago - listar propios aprobado
GET {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}

### 18 - Subastas - Listado invitado sin precios
GET {{baseUrl}}/api/subastas

### 19 - Subastas - Detalle invitado
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}

### 20 - Subastas - Catalogo invitado sin precios/live
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/catalogo

### 21 - Subastas - Catalogo autenticado con precios
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/catalogo
Authorization: Bearer {{accessAprobado}}

### 22 - Items - Detalle autenticado
GET {{baseUrl}}/api/items/{{itemActivoId}}
Authorization: Bearer {{accessAprobado}}

### 23 - Subastas - Verificacion aprobado en subasta live
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/verificacion
Authorization: Bearer {{accessAprobado}}

### 24 - Subastas - Puja actual aprobado
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/puja-actual
Authorization: Bearer {{accessAprobado}}

### 25 - Subastas - Verificacion multa: puede mirar, no pujar
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/verificacion
Authorization: Bearer {{accessMulta}}

### 26 - Compras - Listar propias aprobado
GET {{baseUrl}}/api/compras?page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 27 - Compras - Filtrar por pagos_extra_pendientes
GET {{baseUrl}}/api/compras?page=0&size=20&estado=pagos_extra_pendientes
Authorization: Bearer {{accessAprobado}}

### 28 - Compras - Detalle compra seed
GET {{baseUrl}}/api/compras/{{compraPagosExtraId}}
Authorization: Bearer {{accessAprobado}}

### 29 - Compras - Documentos compra seed
GET {{baseUrl}}/api/compras/{{compraPagosExtraId}}/documentos
Authorization: Bearer {{accessAprobado}}

### 30 - Consignacion - Requisitos consignador
GET {{baseUrl}}/api/consignaciones/requisitos
Authorization: Bearer {{accessConsignador}}

### 31 - Consignacion - Listar propias consignador
GET {{baseUrl}}/api/consignaciones?page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 32 - Consignacion - Filtro activas
GET {{baseUrl}}/api/consignaciones?filtro=activas&page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 33 - Consignacion - Filtro vendidas
GET {{baseUrl}}/api/consignaciones?filtro=vendidas&page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 34 - Admin - Sin key debe fallar
GET {{baseUrl}}/api/admin/consignaciones

### 35 - Admin - Con key debe devolver 200
GET {{baseUrl}}/api/admin/consignaciones
X-QuickBid-Admin-Key: {{adminKey}}


# =============================================================================
# 01_auth_registro_medios.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 01 auth, registro, direcciones y medios
# -----------------------------------------------------------------------------
# Ejecutar preferentemente sobre base limpia. Algunos POST pueden dar 409 si se
# repiten por duplicados o máximos alcanzados.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaAprobadaId = 3001
@medioPagoPendienteChequeId = 5003

@accessAprobado = {{loginAprobado.response.body.$.data.accessToken}}
@accessBloqueado = {{loginBloqueado.response.body.$.data.accessToken}}
@newAddressId = {{crearDireccionAprobado.response.body.$.data.id}}
@newCardId = {{crearTarjetaAprobado.response.body.$.data.id}}
@newBankId = {{crearCuentaBancariaAprobado.response.body.$.data.id}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login aprobado
# @name loginAprobado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "aprobado@quickbid.demo",
  "clave": "Demo123!"
}

### 02 - Login bloqueado limitado
# @name loginBloqueado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "bloqueado@quickbid.demo",
  "clave": "Demo123!"
}

### 03 - Bloqueado no puede navegar endpoints normales
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessBloqueado}}

### 04 - Direcciones - listar
GET {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}

### 05 - Direcciones - crear nueva dirección
# @name crearDireccionAprobado
POST {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "alias": "Casa HTTP {{$timestamp}}",
  "destinatario": "Ana Aprobada",
  "calle": "Av. Demo",
  "numero": "{{$timestamp}}",
  "piso": "2B",
  "codigoPostal": "C1000",
  "localidad": "Buenos Aires",
  "provincia": "Buenos Aires",
  "pais": "Argentina",
  "telefono": "+54 11 5555 0101"
}

### 06 - Direcciones - marcar principal la creada
PATCH {{baseUrl}}/api/usuario/direcciones-envio/{{newAddressId}}/principal
Authorization: Bearer {{accessAprobado}}

### 07 - Direcciones - listar luego de crear
GET {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}

### 08 - Medios - listar propios
GET {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}

### 09 - Medios - registrar tarjeta ficticia pendiente
# @name crearTarjetaAprobado
POST {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "tipo": "tarjeta",
  "moneda": "ARS",
  "nacional": true,
  "titular": "Ana Aprobada",
  "numeroTarjeta": "411111{{$timestamp}}",
  "cvv": "123",
  "vencimientoMes": 12,
  "vencimientoAnio": 2030,
  "marca": "Visa"
}

### 10 - Admin - verificar tarjeta creada con limiteAprobado obligatorio
POST {{baseUrl}}/api/admin/medios-pago/{{newCardId}}/verificar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "limiteAprobado": 250000
}

### 11 - Medios - marcar tarjeta creada como principal
PATCH {{baseUrl}}/api/usuario/medios-pago/{{newCardId}}/principal
Authorization: Bearer {{accessAprobado}}

### 12 - Medios - registrar cuenta bancaria pendiente
# @name crearCuentaBancariaAprobado
POST {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "tipo": "cuenta_bancaria",
  "moneda": "ARS",
  "nacional": true,
  "titular": "Ana Aprobada",
  "numeroCuenta": "000123{{$timestamp}}",
  "cbuCvu": "0000003100{{$timestamp}}",
  "nombreBanco": "Banco Demo Argentina",
  "alias": "ANA.DEMO.HTTP{{$timestamp}}"
}

### 13 - Admin - rechazar cuenta bancaria creada
POST {{baseUrl}}/api/admin/medios-pago/{{newBankId}}/rechazar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "motivo": "Prueba de rechazo manual"
}

### 14 - Medios - registrar cheque con imagenes reales
# @name crearChequeAprobado
POST {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="moneda"

ARS
--QuickBidBoundary
Content-Disposition: form-data; name="nacional"

true
--QuickBidBoundary
Content-Disposition: form-data; name="titular"

Ana Aprobada
--QuickBidBoundary
Content-Disposition: form-data; name="numeroCheque"

CHK-HTTP-{{$timestamp}}
--QuickBidBoundary
Content-Disposition: form-data; name="monto"

150000
--QuickBidBoundary
Content-Disposition: form-data; name="fechaVencimiento"

2030-12-31
--QuickBidBoundary
Content-Disposition: form-data; name="bancoEmisor"

Banco Demo Argentina
--QuickBidBoundary
Content-Disposition: form-data; name="fotoAnverso"; filename="cheque-frente.png"
Content-Type: image/png

< ./fixtures/cheque-frente.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotoReverso"; filename="cheque-dorso.png"
Content-Type: image/png

< ./fixtures/cheque-dorso.png
--QuickBidBoundary--

### 15 - Admin - listar pendientes
GET {{baseUrl}}/api/admin/medios-pago?estado=pendiente_verificacion
X-QuickBid-Admin-Key: {{adminKey}}

### 16 - Admin - verificar cheque seed pendiente con limiteAprobado
POST {{baseUrl}}/api/admin/medios-pago/{{medioPagoPendienteChequeId}}/verificar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "limiteAprobado": 150000
}

### 17 - Admin - procesar medios expirados a vencido
POST {{baseUrl}}/api/admin/medios-pago/vencer-expirados
X-QuickBid-Admin-Key: {{adminKey}}

### 18 - Registro etapa 1 con email unico
# @name registroEtapa1
POST {{baseUrl}}/api/auth/registro/etapa1
Content-Type: application/json

{
  "email": "nuevo{{$timestamp}}@quickbid.demo",
  "nombre": "Nuevo",
  "apellido": "Demo",
  "domicilioLegal": "Calle Demo 123",
  "idPaisOrigen": 1
}

### 19 - Registro etapa 2 con campos finales fotoFrenteDni/fotoDorsoDni
POST {{baseUrl}}/api/auth/registro/etapa2
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="email"

{{registroEtapa1.request.body.$.email}}
--QuickBidBoundary
Content-Disposition: form-data; name="fotoFrenteDni"; filename="dni-frente.png"
Content-Type: image/png

< ./fixtures/dni-frente.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotoDorsoDni"; filename="dni-dorso.png"
Content-Type: image/png

< ./fixtures/dni-dorso.png
--QuickBidBoundary--

### 20 - Registro etapa 2 con PDF debe fallar
POST {{baseUrl}}/api/auth/registro/etapa2
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="email"

{{registroEtapa1.request.body.$.email}}
--QuickBidBoundary
Content-Disposition: form-data; name="fotoFrenteDni"; filename="factura-demo.pdf"
Content-Type: application/pdf

< ./fixtures/factura-demo.pdf
--QuickBidBoundary
Content-Disposition: form-data; name="fotoDorsoDni"; filename="dni-dorso.png"
Content-Type: image/png

< ./fixtures/dni-dorso.png
--QuickBidBoundary--

### 21 - Etapa 3 con setup_token placeholder
# Para ejecutar, reemplazar {{setupToken}} por el token real recibido por mail/log/DB.
POST {{baseUrl}}/api/auth/registro/etapa3
Content-Type: application/json

{
  "setup_token": "{{setupToken}}",
  "claveNueva": "Nueva123!",
  "claveConfirmacion": "Nueva123!"
}

### 22 - Cambio de clave autenticado - usar solo en base aislada
# Cambia la clave de aprobado@quickbid.demo. No ejecutar si vas a seguir usando Demo123!.
PUT {{baseUrl}}/api/auth/cambiar-clave
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "claveActual": "Demo123!",
  "claveNueva": "Demo123!",
  "claveConfirmacion": "Demo123!"
}


# =============================================================================
# 02_pujas_compras_flujo_exitoso.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 02 pujas + cierre de lote + compra/pago extras
# -----------------------------------------------------------------------------
# Ejecutar sobre base limpia. No repetir sin resetear: cierra lote 6001.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@subastaEnVivoId = 6001
@itemActivoId = 9001
@medioPagoConsignadorArsId = 5005
@medioPagoMultaArsId = 5004
@compraPagosExtraId = 13002
@medioPagoAprobadoArsId = 5001
@direccionEnvioAprobadoId = 5101

@accessAprobado = {{loginAprobado.response.body.$.data.accessToken}}
@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}
@accessMulta = {{loginMulta.response.body.$.data.accessToken}}
@newPurchaseId = {{cerrarLote6001.response.body.$.data.id}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login aprobado
# @name loginAprobado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "aprobado@quickbid.demo", "clave": "Demo123!" }

### 02 - Login consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "consignador@quickbid.demo", "clave": "Demo123!" }

### 03 - Login multa
# @name loginMulta
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "multa@quickbid.demo", "clave": "Demo123!" }

### 04 - Verificacion aprobado en subasta live
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/verificacion
Authorization: Bearer {{accessAprobado}}

### 05 - Puja actual antes de pujar
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/puja-actual
Authorization: Bearer {{accessAprobado}}

### 06 - Puja aceptada con idempotencyKey obligatorio
# @name pujaConsignador
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 25300,
  "medioPagoId": {{medioPagoConsignadorArsId}},
  "clientStateVersion": 1,
  "idempotencyKey": "manual-puja-consignador-001"
}

### 07 - Repetir misma puja: debe ser idempotente, no duplicar
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 25300,
  "medioPagoId": {{medioPagoConsignadorArsId}},
  "clientStateVersion": 1,
  "idempotencyKey": "manual-puja-consignador-001"
}

### 08 - Puja sin idempotencyKey debe fallar por validacion
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 26000,
  "medioPagoId": {{medioPagoAprobadoArsId}},
  "clientStateVersion": 1
}

### 09 - Usuario con multa no puede pujar
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessMulta}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 26000,
  "medioPagoId": {{medioPagoMultaArsId}},
  "clientStateVersion": 1,
  "idempotencyKey": "manual-puja-multa-001"
}

### 10 - Admin - Cerrar lote con pago automatico exitoso
# @name cerrarLote6001
POST {{baseUrl}}/api/admin/subastas/{{subastaEnVivoId}}/cerrar-lote?resultado=SUCCESS
X-QuickBid-Admin-Key: {{adminKey}}

### 11 - Admin - Procesar timers de subasta, si hubiera vencidos
POST {{baseUrl}}/api/admin/subastas/timers/procesar
X-QuickBid-Admin-Key: {{adminKey}}

### 12 - Compras - Detalle compra generada por cierre de lote
GET {{baseUrl}}/api/compras/{{newPurchaseId}}
Authorization: Bearer {{accessConsignador}}

### 13 - Compras - Listar propias consignador
GET {{baseUrl}}/api/compras?page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 14 - Compras - Filtrar compras aprobado por estado
GET {{baseUrl}}/api/compras?page=0&size=20&estado=pagos_extra_pendientes
Authorization: Bearer {{accessAprobado}}

### 15 - Seed compra 13002 - Configurar envio con direccion congelada
PUT {{baseUrl}}/api/compras/{{compraPagosExtraId}}/entrega
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "tipo": "envio",
  "direccionEnvioId": {{direccionEnvioAprobadoId}}
}

### 16 - Seed compra 13002 - Pagar extras
POST {{baseUrl}}/api/compras/{{compraPagosExtraId}}/pagar
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "medioPagoId": {{medioPagoAprobadoArsId}},
  "idempotencyKey": "manual-extras-001"
}

### 17 - Seed compra 13002 - Documentos luego de pagar extras
GET {{baseUrl}}/api/compras/{{compraPagosExtraId}}/documentos
Authorization: Bearer {{accessAprobado}}


# =============================================================================
# 03_multas_alternativas.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 03 multas alternativas
# -----------------------------------------------------------------------------
# Elegir SOLO una rama por base limpia:
# - Rama A: pagar compra + multa.
# - Rama B: vencer multa y bloquear cuenta.
# Si ejecutás una, la otra puede devolver 409/403 por cambio de estado.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@compraMultaId = 13001
@multaId = 14001
@medioPagoMultaArsId = 5004

@accessMulta = {{loginMulta.response.body.$.data.accessToken}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login usuario con restriccion por multa
# @name loginMulta
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "multa@quickbid.demo", "clave": "Demo123!" }

### 02A - RAMA A - Pagar adjudicacion + multa juntos
POST {{baseUrl}}/api/compras/{{compraMultaId}}/pagar-con-multa
Authorization: Bearer {{accessMulta}}
Content-Type: application/json

{
  "medioPagoId": {{medioPagoMultaArsId}},
  "idempotencyKey": "manual-multa-pago-001"
}

### 03A - RAMA A - Ver perfil luego de pagar multa
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessMulta}}

### 04A - RAMA A - Documentos/recibo de multa
GET {{baseUrl}}/api/compras/{{compraMultaId}}/documentos
Authorization: Bearer {{accessMulta}}

### 02B - RAMA B - Vencer multa seed manualmente
POST {{baseUrl}}/api/admin/multas/{{multaId}}/vencer
X-QuickBid-Admin-Key: {{adminKey}}

### 03B - RAMA B - Procesar multas vencidas masivas
POST {{baseUrl}}/api/admin/multas/vencer-expiradas
X-QuickBid-Admin-Key: {{adminKey}}

### 04B - RAMA B - Perfil puede quedar bloqueado y responder 403
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessMulta}}

### 05B - RAMA B - Login limitado si quedó bloqueada_permanente
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "multa@quickbid.demo", "clave": "Demo123!" }


# =============================================================================
# 04_consignacion_flujo_nuevo_feliz.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 04 consignación nueva / flujo feliz
# -----------------------------------------------------------------------------
# Ejecutar sobre base limpia. Crea una consignación nueva y la avanza hasta
# acuerdo aceptado/publicación. No repetir completo sin resetear.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaConsignadorId = 3004
@medioPagoConsignadorArsId = 5005
@subastaPublicableId = 6004
@catalogoPublicableId = 7004

@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}
@newConsignacionId = {{crearConsignacion.response.body.$.data.id}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "consignador@quickbid.demo", "clave": "Demo123!" }

### 02 - Consignacion - Requisitos
GET {{baseUrl}}/api/consignaciones/requisitos
Authorization: Bearer {{accessConsignador}}

### 03 - Consignacion - Crear nueva con segmento y categoriaSubasta separados
# @name crearConsignacion
POST {{baseUrl}}/api/consignaciones
Authorization: Bearer {{accessConsignador}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="segmento"

arte
--QuickBidBoundary
Content-Disposition: form-data; name="categoriaSubasta"

comun
--QuickBidBoundary
Content-Disposition: form-data; name="aceptaTyC"

true
--QuickBidBoundary
Content-Disposition: form-data; name="declaracionPropiedadYOrigenLicito"

true
--QuickBidBoundary
Content-Disposition: form-data; name="titulo"

Vasija HTTP {{$timestamp}}
--QuickBidBoundary
Content-Disposition: form-data; name="descripcion"

Pieza de prueba manual con seis fotos.
--QuickBidBoundary
Content-Disposition: form-data; name="historia"

Historia resumida de prueba.
--QuickBidBoundary
Content-Disposition: form-data; name="fechaAproximada"

1970
--QuickBidBoundary
Content-Disposition: form-data; name="esObraDeArte"

false
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-01.png"
Content-Type: image/png

< ./fixtures/foto-01.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-02.png"
Content-Type: image/png

< ./fixtures/foto-02.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-03.png"
Content-Type: image/png

< ./fixtures/foto-03.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-04.png"
Content-Type: image/png

< ./fixtures/foto-04.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-05.png"
Content-Type: image/png

< ./fixtures/foto-05.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-06.png"
Content-Type: image/png

< ./fixtures/foto-06.png
--QuickBidBoundary--

### 04 - Consignacion - Detalle nueva
GET {{baseUrl}}/api/consignaciones/{{newConsignacionId}}
Authorization: Bearer {{accessConsignador}}

### 05 - Admin - Pedir documentacion
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/pedir-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Se requiere factura o comprobante de origen" }

### 06 - Consignacion - Subir documentacion de origen
POST {{baseUrl}}/api/consignaciones/{{newConsignacionId}}/documentacion-origen
Authorization: Bearer {{accessConsignador}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="facturaCompra"; filename="factura-demo.pdf"
Content-Type: application/pdf

< ./fixtures/factura-demo.pdf
--QuickBidBoundary
Content-Disposition: form-data; name="observaciones"

Factura de compra ficticia para prueba manual.
--QuickBidBoundary--

### 07 - Admin - Revisar documentacion aprobada
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/revisar-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "aprobada": true, "motivo": "Documentacion suficiente" }

### 08 - Admin - Marcar recepcion fisica
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/marcar-recibida-fisicamente
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "ubicacionFisica": "Deposito HTTP A1" }

### 09 - Admin - Aprobar revision fisica
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/aprobar-revision-fisica
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Estado fisico correcto" }

### 10 - Admin - Verificar consignador como duenio
POST {{baseUrl}}/api/admin/consignadores/{{cuentaConsignadorId}}/verificar-duenio
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "financiera": true, "judicial": true, "riesgo": 1 }

### 11 - Admin - Proponer acuerdo con comisiones distintas
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/proponer-acuerdo
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "valorBase": 100000,
  "moneda": "ARS",
  "comisionCompradorPct": 10,
  "comisionVendedorPct": 15,
  "condiciones": "Condiciones demo HTTP: comprador 10%, vendedor 15%."
}

### 12 - Consignacion - Aceptar acuerdo exige ambos checks true
POST {{baseUrl}}/api/consignaciones/{{newConsignacionId}}/acuerdo/aceptar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "leyoContrato": true,
  "aceptaClausulasPlazos": true
}

### 13 - Admin - Asignar/publicar a subasta/catalogo
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/asignar-subasta
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "subastaId": {{subastaPublicableId}},
  "catalogoId": {{catalogoPublicableId}}
}

### 14 - Consignacion - Detalle final
GET {{baseUrl}}/api/consignaciones/{{newConsignacionId}}
Authorization: Bearer {{accessConsignador}}

### 15 - Consignacion - Filtro activas
GET {{baseUrl}}/api/consignaciones?filtro=activas&page=0&size=20
Authorization: Bearer {{accessConsignador}}


# =============================================================================
# 05_consignacion_seeds_ramas_independientes.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 05 consignación seeds / ramas independientes
# -----------------------------------------------------------------------------
# NO ejecutar todo como flujo único. Cada bloque usa un seed en estado distinto.
# Si un bloque cambia estado, repetirlo puede devolver 409 correcto.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaConsignadorId = 3004
@medioPagoConsignadorArsId = 5005
@subastaPublicableId = 6004
@catalogoPublicableId = 7004
@consignacionPendienteId = 16001
@consignacionDocumentacionId = 16002
@consignacionFisicaId = 16003
@consignacionAcuerdoId = 16004
@consignacionDevolucionId = 16006
@consignacionLiquidadaId = 16007
@consignacionPublicableId = 16008

@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "consignador@quickbid.demo", "clave": "Demo123!" }

### A1 - Seed 16001 - Pedir documentacion
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionPendienteId}}/pedir-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Se requiere documentacion adicional de origen" }

### B1 - Seed 16002 - Subir documentacion de origen
POST {{baseUrl}}/api/consignaciones/{{consignacionDocumentacionId}}/documentacion-origen
Authorization: Bearer {{accessConsignador}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="facturaCompra"; filename="factura-demo.pdf"
Content-Type: application/pdf

< ./fixtures/factura-demo.pdf
--QuickBidBoundary
Content-Disposition: form-data; name="observaciones"

Factura de compra ficticia para prueba manual.
--QuickBidBoundary--

### B2 - Seed 16002 - Revisar documentacion aprobada
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionDocumentacionId}}/revisar-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "aprobada": true, "motivo": "Documentacion suficiente" }

### C1 - Seed 16003 - Marcar recepcion fisica
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionFisicaId}}/marcar-recibida-fisicamente
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "ubicacionFisica": "Deposito seed C1" }

### C2 - Seed 16003 - Aprobar revision fisica
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionFisicaId}}/aprobar-revision-fisica
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Estado fisico correcto" }

### C3 - Verificar consignador como duenio
POST {{baseUrl}}/api/admin/consignadores/{{cuentaConsignadorId}}/verificar-duenio
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "financiera": true, "judicial": true, "riesgo": 1 }

### C4 - Seed 16003 - Proponer acuerdo con comisiones distintas
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionFisicaId}}/proponer-acuerdo
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "valorBase": 100000,
  "moneda": "ARS",
  "comisionCompradorPct": 10,
  "comisionVendedorPct": 15,
  "condiciones": "Condiciones demo seed C"
}

### D1 - Seed 16004 - Aceptar acuerdo pendiente
POST {{baseUrl}}/api/consignaciones/{{consignacionAcuerdoId}}/acuerdo/aceptar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{ "leyoContrato": true, "aceptaClausulasPlazos": true }

### E1 - Seed 16004 - Rechazar acuerdo pendiente
# Ejecutar en base limpia alternativa, NO despues de D1.
POST {{baseUrl}}/api/consignaciones/{{consignacionAcuerdoId}}/acuerdo/rechazar
Authorization: Bearer {{accessConsignador}}

### F1 - Seed 16006 - Seleccionar devolucion por envio
POST {{baseUrl}}/api/consignaciones/{{consignacionDevolucionId}}/devolucion
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "modalidad": "envio",
  "direccion": "Av. Devolucion 123",
  "codigoPostal": "C1000",
  "localidad": "Buenos Aires",
  "provincia": "Buenos Aires",
  "telefonoContacto": "+54 11 5555 0202"
}

### F2 - Seed 16006 - Pagar envio de devolucion
POST {{baseUrl}}/api/consignaciones/{{consignacionDevolucionId}}/devolucion/pagar-envio
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "medioPagoId": {{medioPagoConsignadorArsId}},
  "idempotencyKey": "manual-devolucion-001"
}

### G1 - Seed 16008 - Asignar consignacion aceptada a subasta/catalogo
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionPublicableId}}/asignar-subasta
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "subastaId": {{subastaPublicableId}},
  "catalogoId": {{catalogoPublicableId}}
}

### H1 - Seed 16007 - Liquidacion existente/detalle
GET {{baseUrl}}/api/consignaciones/{{consignacionLiquidadaId}}
Authorization: Bearer {{accessConsignador}}

### I1 - Listar rechazadas
GET {{baseUrl}}/api/consignaciones?filtro=rechazadas&page=0&size=20
Authorization: Bearer {{accessConsignador}}

### I2 - Listar vendidas
GET {{baseUrl}}/api/consignaciones?filtro=vendidas&page=0&size=20
Authorization: Bearer {{accessConsignador}}


# =============================================================================
# 98_admin_jobs_smoke.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 98 admin jobs / vencimientos / limpieza
# -----------------------------------------------------------------------------
# Ejecutar al final de un ciclo de pruebas. Modifica estados si hay vencimientos.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Procesar todos los vencimientos auxiliares
POST {{baseUrl}}/api/admin/vencimientos/procesar
X-QuickBid-Admin-Key: {{adminKey}}

### 02 - Medios verificados expirados a vencido
POST {{baseUrl}}/api/admin/medios-pago/vencer-expirados
X-QuickBid-Admin-Key: {{adminKey}}

### 03 - Multas expiradas
POST {{baseUrl}}/api/admin/multas/vencer-expiradas
X-QuickBid-Admin-Key: {{adminKey}}

### 04 - Compras vencidas por extras
POST {{baseUrl}}/api/admin/compras/abandonar-vencidas
X-QuickBid-Admin-Key: {{adminKey}}

### 05 - Devoluciones de consignación vencidas
POST {{baseUrl}}/api/admin/consignaciones/devoluciones/vencer
X-QuickBid-Admin-Key: {{adminKey}}

### 06 - Limpiar notificaciones antiguas 30/90
POST {{baseUrl}}/api/admin/notificaciones/limpiar
X-QuickBid-Admin-Key: {{adminKey}}

### 07 - Procesar timers de subastas vencidos
POST {{baseUrl}}/api/admin/subastas/timers/procesar
X-QuickBid-Admin-Key: {{adminKey}}


# =============================================================================
# 99_mail_real_smoke.http
# =============================================================================

# -----------------------------------------------------------------------------
# QuickBid - 99 SMTP real smoke
# -----------------------------------------------------------------------------
# Reiniciar backend antes con:
#   APP_MAIL_ENABLED=true
#   APP_MAIL_FROM=...
#   APP_FRONTEND_BASE_URL=...
#   SPRING_MAIL_HOST/PORT/USERNAME/PASSWORD=...
# No automatiza la validacion de casilla: revisar el email manualmente.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key
@medioPagoPendienteChequeId = 5003

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Recuperacion de clave: debe enviar email real si SMTP esta activo
POST {{baseUrl}}/api/auth/recuperar-clave
Content-Type: application/json

{ "email": "aprobado@quickbid.demo" }

### 02 - Reenvio de link de registro generico
POST {{baseUrl}}/api/auth/registro/reenviar-link
Content-Type: application/json

{ "email": "pendiente@quickbid.demo" }

### 03 - Admin verifica medio pendiente y dispara notificacion/email si SMTP de negocio está activo
POST {{baseUrl}}/api/admin/medios-pago/{{medioPagoPendienteChequeId}}/verificar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "limiteAprobado": 150000 }
