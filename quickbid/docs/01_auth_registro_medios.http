# -----------------------------------------------------------------------------
# QuickBid - 01 auth, registro, direcciones y medios
# -----------------------------------------------------------------------------
# Ejecutar preferentemente sobre base limpia. Algunos POST pueden dar 409 si se
# repiten por duplicados o máximos alcanzados.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaAprobadaId = 3001
@medioPagoPendienteChequeId = 5003

@accessAprobado = {{loginAprobado.response.body.$.data.accessToken}}
@accessBloqueado = {{loginBloqueado.response.body.$.data.accessToken}}
@newAddressId = {{crearDireccionAprobado.response.body.$.data.id}}
@newCardId = {{crearTarjetaAprobado.response.body.$.data.id}}
@newBankId = {{crearCuentaBancariaAprobado.response.body.$.data.id}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login aprobado
# @name loginAprobado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "aprobado@quickbid.demo",
  "clave": "Demo123!"
}

### 02 - Login bloqueado limitado
# @name loginBloqueado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "bloqueado@quickbid.demo",
  "clave": "Demo123!"
}

### 03 - Bloqueado no puede navegar endpoints normales
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessBloqueado}}

### 04 - Direcciones - listar
GET {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}

### 05 - Direcciones - crear nueva dirección
# @name crearDireccionAprobado
POST {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "alias": "Casa HTTP {{$timestamp}}",
  "destinatario": "Ana Aprobada",
  "calle": "Av. Demo",
  "numero": "{{$timestamp}}",
  "piso": "2B",
  "codigoPostal": "C1000",
  "localidad": "Buenos Aires",
  "provincia": "Buenos Aires",
  "pais": "Argentina",
  "telefono": "+54 11 5555 0101"
}

### 06 - Direcciones - marcar principal la creada
PATCH {{baseUrl}}/api/usuario/direcciones-envio/{{newAddressId}}/principal
Authorization: Bearer {{accessAprobado}}

### 07 - Direcciones - listar luego de crear
GET {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}

### 08 - Medios - listar propios
GET {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}

### 09 - Medios - registrar tarjeta ficticia pendiente
# @name crearTarjetaAprobado
POST {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "tipo": "tarjeta",
  "moneda": "ARS",
  "nacional": true,
  "titular": "Ana Aprobada",
  "numeroTarjeta": "411111{{$timestamp}}",
  "cvv": "123",
  "vencimientoMes": 12,
  "vencimientoAnio": 2030,
  "marca": "Visa"
}

### 10 - Admin - verificar tarjeta creada con limiteAprobado obligatorio
POST {{baseUrl}}/api/admin/medios-pago/{{newCardId}}/verificar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "limiteAprobado": 250000
}

### 11 - Medios - marcar tarjeta creada como principal
PATCH {{baseUrl}}/api/usuario/medios-pago/{{newCardId}}/principal
Authorization: Bearer {{accessAprobado}}

### 12 - Medios - registrar cuenta bancaria pendiente
# @name crearCuentaBancariaAprobado
POST {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "tipo": "cuenta_bancaria",
  "moneda": "ARS",
  "nacional": true,
  "titular": "Ana Aprobada",
  "numeroCuenta": "000123{{$timestamp}}",
  "cbuCvu": "0000003100{{$timestamp}}",
  "nombreBanco": "Banco Demo Argentina",
  "alias": "ANA.DEMO.HTTP{{$timestamp}}"
}

### 13 - Admin - rechazar cuenta bancaria creada
POST {{baseUrl}}/api/admin/medios-pago/{{newBankId}}/rechazar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "motivo": "Prueba de rechazo manual"
}

### 14 - Medios - registrar cheque con imagenes reales
# @name crearChequeAprobado
POST {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="moneda"

ARS
--QuickBidBoundary
Content-Disposition: form-data; name="nacional"

true
--QuickBidBoundary
Content-Disposition: form-data; name="titular"

Ana Aprobada
--QuickBidBoundary
Content-Disposition: form-data; name="numeroCheque"

CHK-HTTP-{{$timestamp}}
--QuickBidBoundary
Content-Disposition: form-data; name="monto"

150000
--QuickBidBoundary
Content-Disposition: form-data; name="fechaVencimiento"

2030-12-31
--QuickBidBoundary
Content-Disposition: form-data; name="bancoEmisor"

Banco Demo Argentina
--QuickBidBoundary
Content-Disposition: form-data; name="fotoAnverso"; filename="cheque-frente.png"
Content-Type: image/png

< ./fixtures/cheque-frente.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotoReverso"; filename="cheque-dorso.png"
Content-Type: image/png

< ./fixtures/cheque-dorso.png
--QuickBidBoundary--

### 15 - Admin - listar pendientes
GET {{baseUrl}}/api/admin/medios-pago?estado=pendiente_verificacion
X-QuickBid-Admin-Key: {{adminKey}}

### 16 - Admin - verificar cheque seed pendiente con limiteAprobado
POST {{baseUrl}}/api/admin/medios-pago/{{medioPagoPendienteChequeId}}/verificar
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "limiteAprobado": 150000
}

### 17 - Admin - procesar medios expirados a vencido
POST {{baseUrl}}/api/admin/medios-pago/vencer-expirados
X-QuickBid-Admin-Key: {{adminKey}}

### 18 - Registro etapa 1 con email unico
# @name registroEtapa1
POST {{baseUrl}}/api/auth/registro/etapa1
Content-Type: application/json

{
  "email": "nuevo{{$timestamp}}@quickbid.demo",
  "nombre": "Nuevo",
  "apellido": "Demo",
  "domicilioLegal": "Calle Demo 123",
  "idPaisOrigen": 32
}

### 19 - Registro etapa 2 con campos finales fotoFrenteDni/fotoDorsoDni
POST {{baseUrl}}/api/auth/registro/etapa2
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="email"

{{registroEtapa1.request.body.$.email}}
--QuickBidBoundary
Content-Disposition: form-data; name="fotoFrenteDni"; filename="dni-frente.png"
Content-Type: image/png

< ./fixtures/dni-frente.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotoDorsoDni"; filename="dni-dorso.png"
Content-Type: image/png

< ./fixtures/dni-dorso.png
--QuickBidBoundary--

### 20 - Registro etapa 2 con PDF debe fallar
POST {{baseUrl}}/api/auth/registro/etapa2
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="email"

{{registroEtapa1.request.body.$.email}}
--QuickBidBoundary
Content-Disposition: form-data; name="fotoFrenteDni"; filename="factura-demo.pdf"
Content-Type: application/pdf

< ./fixtures/factura-demo.pdf
--QuickBidBoundary
Content-Disposition: form-data; name="fotoDorsoDni"; filename="dni-dorso.png"
Content-Type: image/png

< ./fixtures/dni-dorso.png
--QuickBidBoundary--

### 21 - Etapa 3 con setup_token placeholder
# Para ejecutar, reemplazar {{setupToken}} por el token real recibido por mail/log/DB.
POST {{baseUrl}}/api/auth/registro/etapa3
Content-Type: application/json

{
  "setup_token": "{{setupToken}}",
  "claveNueva": "Nueva123!",
  "claveConfirmacion": "Nueva123!"
}

### 22 - Cambio de clave autenticado - usar solo en base aislada
# Cambia la clave de aprobado@quickbid.demo. No ejecutar si vas a seguir usando Demo123!.
PUT {{baseUrl}}/api/auth/cambiar-clave
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "claveActual": "Demo123!",
  "claveNueva": "Demo123!",
  "claveConfirmacion": "Demo123!"
}
