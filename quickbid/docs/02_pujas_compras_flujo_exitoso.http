# -----------------------------------------------------------------------------
# QuickBid - 02 pujas + cierre de lote + compra/pago extras
# -----------------------------------------------------------------------------
# Ejecutar sobre base limpia. No repetir sin resetear: cierra lote 6001.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@subastaEnVivoId = 6001
@itemActivoId = 9001
@medioPagoConsignadorArsId = 5005
@medioPagoMultaArsId = 5004
@compraPagosExtraId = 13002
@medioPagoAprobadoArsId = 5001
@direccionEnvioAprobadoId = 5101

@accessAprobado = {{loginAprobado.response.body.$.data.accessToken}}
@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}
@accessMulta = {{loginMulta.response.body.$.data.accessToken}}
@newPurchaseId = {{cerrarLote6001.response.body.$.data.id}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login aprobado
# @name loginAprobado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "aprobado@quickbid.demo", "clave": "Demo123!" }

### 02 - Login consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "consignador@quickbid.demo", "clave": "Demo123!" }

### 03 - Login multa
# @name loginMulta
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "multa@quickbid.demo", "clave": "Demo123!" }

### 04 - Verificacion aprobado en subasta live
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/verificacion
Authorization: Bearer {{accessAprobado}}

### 05 - Puja actual antes de pujar
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/puja-actual
Authorization: Bearer {{accessAprobado}}

### 06 - Puja aceptada con idempotencyKey obligatorio
# @name pujaConsignador
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 25300,
  "medioPagoId": {{medioPagoConsignadorArsId}},
  "clientStateVersion": 1,
  "idempotencyKey": "manual-puja-consignador-001"
}

### 07 - Repetir misma puja: debe ser idempotente, no duplicar
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 25300,
  "medioPagoId": {{medioPagoConsignadorArsId}},
  "clientStateVersion": 1,
  "idempotencyKey": "manual-puja-consignador-001"
}

### 08 - Puja sin idempotencyKey debe fallar por validacion
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 26000,
  "medioPagoId": {{medioPagoAprobadoArsId}},
  "clientStateVersion": 1
}

### 09 - Usuario con multa no puede pujar
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/pujar
Authorization: Bearer {{accessMulta}}
Content-Type: application/json

{
  "itemCatalogoId": {{itemActivoId}},
  "monto": 26000,
  "medioPagoId": {{medioPagoMultaArsId}},
  "clientStateVersion": 1,
  "idempotencyKey": "manual-puja-multa-001"
}

### 10 - Admin - Cerrar lote con pago automatico exitoso
# @name cerrarLote6001
POST {{baseUrl}}/api/admin/subastas/{{subastaEnVivoId}}/cerrar-lote?resultado=SUCCESS
X-QuickBid-Admin-Key: {{adminKey}}

### 11 - Admin - Procesar timers de subasta, si hubiera vencidos
POST {{baseUrl}}/api/admin/subastas/timers/procesar
X-QuickBid-Admin-Key: {{adminKey}}

### 12 - Compras - Detalle compra generada por cierre de lote
GET {{baseUrl}}/api/compras/{{newPurchaseId}}
Authorization: Bearer {{accessConsignador}}

### 13 - Compras - Listar propias consignador
GET {{baseUrl}}/api/compras?page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 14 - Compras - Filtrar compras aprobado por estado
GET {{baseUrl}}/api/compras?page=0&size=20&estado=pagos_extra_pendientes
Authorization: Bearer {{accessAprobado}}

### 15 - Seed compra 13002 - Configurar envio con direccion congelada
PUT {{baseUrl}}/api/compras/{{compraPagosExtraId}}/entrega
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "tipo": "envio",
  "direccionEnvioId": {{direccionEnvioAprobadoId}}
}

### 16 - Seed compra 13002 - Pagar extras
POST {{baseUrl}}/api/compras/{{compraPagosExtraId}}/pagar
Authorization: Bearer {{accessAprobado}}
Content-Type: application/json

{
  "medioPagoId": {{medioPagoAprobadoArsId}},
  "idempotencyKey": "manual-extras-001"
}

### 17 - Seed compra 13002 - Documentos luego de pagar extras
GET {{baseUrl}}/api/compras/{{compraPagosExtraId}}/documentos
Authorization: Bearer {{accessAprobado}}
