# -----------------------------------------------------------------------------
# QuickBid - 05 consignación seeds / ramas independientes
# -----------------------------------------------------------------------------
# NO ejecutar todo como flujo único. Cada bloque usa un seed en estado distinto.
# Si un bloque cambia estado, repetirlo puede devolver 409 correcto.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaConsignadorId = 3004
@medioPagoConsignadorArsId = 5005
@subastaPublicableId = 6004
@catalogoPublicableId = 7004
@consignacionPendienteId = 16001
@consignacionDocumentacionId = 16002
@consignacionFisicaId = 16003
@consignacionAcuerdoId = 16004
@consignacionDevolucionId = 16006
@consignacionLiquidadaId = 16007
@consignacionPublicableId = 16008

@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "consignador@quickbid.demo", "clave": "Demo123!" }

### A1 - Seed 16001 - Pedir documentacion
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionPendienteId}}/pedir-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Se requiere documentacion adicional de origen" }

### B1 - Seed 16002 - Subir documentacion de origen
POST {{baseUrl}}/api/consignaciones/{{consignacionDocumentacionId}}/documentacion-origen
Authorization: Bearer {{accessConsignador}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="facturaCompra"; filename="factura-demo.pdf"
Content-Type: application/pdf

< ./fixtures/factura-demo.pdf
--QuickBidBoundary
Content-Disposition: form-data; name="observaciones"

Factura de compra ficticia para prueba manual.
--QuickBidBoundary--

### B2 - Seed 16002 - Revisar documentacion aprobada
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionDocumentacionId}}/revisar-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "aprobada": true, "motivo": "Documentacion suficiente" }

### C1 - Seed 16003 - Marcar recepcion fisica
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionFisicaId}}/marcar-recibida-fisicamente
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "ubicacionFisica": "Deposito seed C1" }

### C2 - Seed 16003 - Aprobar revision fisica
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionFisicaId}}/aprobar-revision-fisica
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Estado fisico correcto" }

### C3 - Verificar consignador como duenio
POST {{baseUrl}}/api/admin/consignadores/{{cuentaConsignadorId}}/verificar-duenio
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "financiera": true, "judicial": true, "riesgo": 1 }

### C4 - Seed 16003 - Proponer acuerdo con comisiones distintas
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionFisicaId}}/proponer-acuerdo
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "valorBase": 100000,
  "moneda": "ARS",
  "comisionCompradorPct": 10,
  "comisionVendedorPct": 15,
  "condiciones": "Condiciones demo seed C"
}

### D1 - Seed 16004 - Aceptar acuerdo pendiente
POST {{baseUrl}}/api/consignaciones/{{consignacionAcuerdoId}}/acuerdo/aceptar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{ "leyoContrato": true, "aceptaClausulasPlazos": true }

### E1 - Seed 16004 - Rechazar acuerdo pendiente
# Ejecutar en base limpia alternativa, NO despues de D1.
POST {{baseUrl}}/api/consignaciones/{{consignacionAcuerdoId}}/acuerdo/rechazar
Authorization: Bearer {{accessConsignador}}

### F1 - Seed 16006 - Seleccionar devolucion por envio
POST {{baseUrl}}/api/consignaciones/{{consignacionDevolucionId}}/devolucion
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "modalidad": "envio",
  "direccion": "Av. Devolucion 123",
  "codigoPostal": "C1000",
  "localidad": "Buenos Aires",
  "provincia": "Buenos Aires",
  "telefonoContacto": "+54 11 5555 0202"
}

### F1 alternativa - Seleccionar devolucion con direccion guardada
POST {{baseUrl}}/api/consignaciones/{{consignacionDevolucionId}}/devolucion
Authorization: Bearer {{consignadorAccessToken}}
Content-Type: application/json

{
  "modalidad": "envio",
  "direccionEnvioId": {{direccionEnvioConsignadorId}}
}

### F2 - Seed 16006 - Pagar envio de devolucion
POST {{baseUrl}}/api/consignaciones/{{consignacionDevolucionId}}/devolucion/pagar-envio
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "medioPagoId": {{medioPagoConsignadorArsId}},
  "idempotencyKey": "manual-devolucion-001"
}

### G1 - Seed 16008 - Asignar consignacion aceptada a subasta/catalogo
POST {{baseUrl}}/api/admin/consignaciones/{{consignacionPublicableId}}/asignar-subasta
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "subastaId": {{subastaPublicableId}},
  "catalogoId": {{catalogoPublicableId}}
}

### H1 - Seed 16007 - Liquidacion existente/detalle
GET {{baseUrl}}/api/consignaciones/{{consignacionLiquidadaId}}
Authorization: Bearer {{accessConsignador}}

### I1 - Listar rechazadas
GET {{baseUrl}}/api/consignaciones?filtro=rechazadas&page=0&size=20
Authorization: Bearer {{accessConsignador}}

### I2 - Listar vendidas
GET {{baseUrl}}/api/consignaciones?filtro=vendidas&page=0&size=20
Authorization: Bearer {{accessConsignador}}
