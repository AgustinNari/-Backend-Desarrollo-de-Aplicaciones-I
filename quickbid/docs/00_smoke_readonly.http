# -----------------------------------------------------------------------------
# QuickBid - 00 smoke readonly / seguro para ejecutar muchas veces
# -----------------------------------------------------------------------------
# Requiere backend levantado con APP_ADMIN_ENABLED=true y
# APP_ADMIN_INTERNAL_KEY=test-admin-key.
# No modifica datos salvo login/refresh/recuperación.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaAprobadaId = 3001
@cuentaMultaId = 3002
@cuentaConsignadorId = 3004
@medioPagoAprobadoArsId = 5001
@medioPagoMultaArsId = 5004
@medioPagoConsignadorArsId = 5005
@subastaEnVivoId = 6001
@subastaEspecialUsdId = 6002
@subastaCerradaId = 6003
@itemActivoId = 9001
@compraMultaId = 13001
@compraPagosExtraId = 13002
@consignacionPendienteId = 16001
@consignacionLiquidadaId = 16007

@accessAprobado = {{loginAprobado.response.body.$.data.accessToken}}
@refreshAprobado = {{loginAprobado.response.body.$.data.refreshToken}}
@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}
@accessMulta = {{loginMulta.response.body.$.data.accessToken}}
@accessBloqueado = {{loginBloqueado.response.body.$.data.accessToken}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Auth - Login usuario aprobado
# @name loginAprobado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "aprobado@quickbid.demo",
  "clave": "Demo123!"
}

### 02 - Auth - Login usuario consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "consignador@quickbid.demo",
  "clave": "Demo123!"
}

### 03 - Auth - Login usuario con restriccion por multa
# @name loginMulta
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "multa@quickbid.demo",
  "clave": "Demo123!"
}

### 04 - Auth - Login usuario bloqueado: ahora es login limitado, no 403
# @name loginBloqueado
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "bloqueado@quickbid.demo",
  "clave": "Demo123!"
}

### 05 - Auth - Sesion actual aprobado
GET {{baseUrl}}/api/auth/sesion
Authorization: Bearer {{accessAprobado}}

### 06 - Auth - Endpoint normal con bloqueado debe quedar bloqueado
# Esperado: 403 ACCOUNT_BLOCKED, aunque el login limitado haya devuelto token.
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessBloqueado}}

### 07 - Auth - Refresh usuario aprobado
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshAprobado}}"
}

### 08 - Auth - Solicitar recuperacion de clave
POST {{baseUrl}}/api/auth/recuperar-clave
Content-Type: application/json

{
  "email": "aprobado@quickbid.demo"
}

### 09 - Usuario - Perfil aprobado
GET {{baseUrl}}/api/usuario/perfil
Authorization: Bearer {{accessAprobado}}

### 10 - Usuario - Estadisticas total
GET {{baseUrl}}/api/usuario/estadisticas?periodo=total
Authorization: Bearer {{accessAprobado}}

### 11 - Usuario - Estadisticas mes
GET {{baseUrl}}/api/usuario/estadisticas?periodo=mes
Authorization: Bearer {{accessAprobado}}

### 12 - Usuario - Historial paginado
GET {{baseUrl}}/api/usuario/historial?page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 13 - Usuario - Notificaciones no leidas
GET {{baseUrl}}/api/usuario/notificaciones?leida=false&page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 14 - Usuario - Notificaciones por categoria/tipo
GET {{baseUrl}}/api/usuario/notificaciones?categoria=subasta&page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 15 - Usuario - Direcciones multiples
GET {{baseUrl}}/api/usuario/direcciones-envio
Authorization: Bearer {{accessAprobado}}

### 16 - Usuario - Direccion legacy compatible
GET {{baseUrl}}/api/usuario/direccion-envio
Authorization: Bearer {{accessAprobado}}

### 17 - Medios de pago - listar propios aprobado
GET {{baseUrl}}/api/usuario/medios-pago
Authorization: Bearer {{accessAprobado}}

### 18 - Subastas - Listado invitado sin precios
GET {{baseUrl}}/api/subastas

### 19 - Subastas - Detalle invitado
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}

### 20 - Subastas - Catalogo invitado sin precios/live
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/catalogo

### 21 - Subastas - Catalogo autenticado con precios
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/catalogo
Authorization: Bearer {{accessAprobado}}

### 22 - Items - Detalle autenticado
GET {{baseUrl}}/api/items/{{itemActivoId}}
Authorization: Bearer {{accessAprobado}}

### 23 - Subastas - Verificacion aprobado en subasta live
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/verificacion
Authorization: Bearer {{accessAprobado}}

### 24 - Subastas - Puja actual aprobado
GET {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/puja-actual
Authorization: Bearer {{accessAprobado}}

### 25 - Subastas - Verificacion multa: puede mirar, no pujar
POST {{baseUrl}}/api/subastas/{{subastaEnVivoId}}/verificacion
Authorization: Bearer {{accessMulta}}

### 26 - Compras - Listar propias aprobado
GET {{baseUrl}}/api/compras?page=0&size=20
Authorization: Bearer {{accessAprobado}}

### 27 - Compras - Filtrar por pagos_extra_pendientes
GET {{baseUrl}}/api/compras?page=0&size=20&estado=pagos_extra_pendientes
Authorization: Bearer {{accessAprobado}}

### 28 - Compras - Detalle compra seed
GET {{baseUrl}}/api/compras/{{compraPagosExtraId}}
Authorization: Bearer {{accessAprobado}}

### 29 - Compras - Documentos compra seed
GET {{baseUrl}}/api/compras/{{compraPagosExtraId}}/documentos
Authorization: Bearer {{accessAprobado}}

### 30 - Consignacion - Requisitos consignador
GET {{baseUrl}}/api/consignaciones/requisitos
Authorization: Bearer {{accessConsignador}}

### 31 - Consignacion - Listar propias consignador
GET {{baseUrl}}/api/consignaciones?page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 32 - Consignacion - Filtro activas
GET {{baseUrl}}/api/consignaciones?filtro=activas&page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 33 - Consignacion - Filtro vendidas
GET {{baseUrl}}/api/consignaciones?filtro=vendidas&page=0&size=20
Authorization: Bearer {{accessConsignador}}

### 34 - Admin - Sin key debe fallar
GET {{baseUrl}}/api/admin/consignaciones

### 35 - Admin - Con key debe devolver 200
GET {{baseUrl}}/api/admin/consignaciones
X-QuickBid-Admin-Key: {{adminKey}}
