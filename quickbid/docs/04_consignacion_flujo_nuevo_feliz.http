# -----------------------------------------------------------------------------
# QuickBid - 04 consignación nueva / flujo feliz
# -----------------------------------------------------------------------------
# Ejecutar sobre base limpia. Crea una consignación nueva y la avanza hasta
# acuerdo aceptado/publicación. No repetir completo sin resetear.
# -----------------------------------------------------------------------------

@baseUrl = http://localhost:8080
@adminKey = test-admin-key

@cuentaConsignadorId = 3004
@medioPagoConsignadorArsId = 5005
@subastaPublicableId = 6004
@catalogoPublicableId = 7004

@accessConsignador = {{loginConsignador.response.body.$.data.accessToken}}
@newConsignacionId = {{crearConsignacion.response.body.$.data.id}}

### 00 - Health
GET {{baseUrl}}/actuator/health

### 01 - Login consignador
# @name loginConsignador
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "email": "consignador@quickbid.demo", "clave": "Demo123!" }

### 02 - Consignacion - Requisitos
GET {{baseUrl}}/api/consignaciones/requisitos
Authorization: Bearer {{accessConsignador}}

### 03 - Consignacion - Crear nueva con segmento y categoriaSubasta separados
# @name crearConsignacion
POST {{baseUrl}}/api/consignaciones
Authorization: Bearer {{accessConsignador}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="segmento"

arte
--QuickBidBoundary
Content-Disposition: form-data; name="categoriaSubasta"

comun
--QuickBidBoundary
Content-Disposition: form-data; name="aceptaTyC"

true
--QuickBidBoundary
Content-Disposition: form-data; name="declaracionPropiedadYOrigenLicito"

true
--QuickBidBoundary
Content-Disposition: form-data; name="titulo"

Vasija HTTP {{$timestamp}}
--QuickBidBoundary
Content-Disposition: form-data; name="descripcion"

Pieza de prueba manual con seis fotos.
--QuickBidBoundary
Content-Disposition: form-data; name="historia"

Historia resumida de prueba.
--QuickBidBoundary
Content-Disposition: form-data; name="fechaAproximada"

1970
--QuickBidBoundary
Content-Disposition: form-data; name="esObraDeArte"

false
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-01.png"
Content-Type: image/png

< ./fixtures/foto-01.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-02.png"
Content-Type: image/png

< ./fixtures/foto-02.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-03.png"
Content-Type: image/png

< ./fixtures/foto-03.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-04.png"
Content-Type: image/png

< ./fixtures/foto-04.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-05.png"
Content-Type: image/png

< ./fixtures/foto-05.png
--QuickBidBoundary
Content-Disposition: form-data; name="fotos"; filename="foto-06.png"
Content-Type: image/png

< ./fixtures/foto-06.png
--QuickBidBoundary--

### 04 - Consignacion - Detalle nueva
GET {{baseUrl}}/api/consignaciones/{{newConsignacionId}}
Authorization: Bearer {{accessConsignador}}

### 05 - Admin - Pedir documentacion
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/pedir-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Se requiere factura o comprobante de origen" }

### 06 - Consignacion - Subir documentacion de origen
POST {{baseUrl}}/api/consignaciones/{{newConsignacionId}}/documentacion-origen
Authorization: Bearer {{accessConsignador}}
Content-Type: multipart/form-data; boundary=QuickBidBoundary

--QuickBidBoundary
Content-Disposition: form-data; name="facturaCompra"; filename="factura-demo.pdf"
Content-Type: application/pdf

< ./fixtures/factura-demo.pdf
--QuickBidBoundary
Content-Disposition: form-data; name="observaciones"

Factura de compra ficticia para prueba manual.
--QuickBidBoundary--

### 07 - Admin - Revisar documentacion aprobada
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/revisar-documentacion
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "aprobada": true, "motivo": "Documentacion suficiente" }

### 08 - Admin - Marcar recepcion fisica
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/marcar-recibida-fisicamente
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "ubicacionFisica": "Deposito HTTP A1" }

### 09 - Admin - Aprobar revision fisica
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/aprobar-revision-fisica
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "motivo": "Estado fisico correcto" }

### 10 - Admin - Verificar consignador como duenio
POST {{baseUrl}}/api/admin/consignadores/{{cuentaConsignadorId}}/verificar-duenio
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{ "financiera": true, "judicial": true, "riesgo": 1 }

### 11 - Admin - Proponer acuerdo con comisiones distintas
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/proponer-acuerdo
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "valorBase": 100000,
  "moneda": "ARS",
  "comisionCompradorPct": 10,
  "comisionVendedorPct": 15,
  "condiciones": "Condiciones demo HTTP: comprador 10%, vendedor 15%."
}

### 12 - Consignacion - Aceptar acuerdo exige ambos checks true
POST {{baseUrl}}/api/consignaciones/{{newConsignacionId}}/acuerdo/aceptar
Authorization: Bearer {{accessConsignador}}
Content-Type: application/json

{
  "leyoContrato": true,
  "aceptaClausulasPlazos": true
}

### 13 - Admin - Asignar/publicar a subasta/catalogo
POST {{baseUrl}}/api/admin/consignaciones/{{newConsignacionId}}/asignar-subasta
X-QuickBid-Admin-Key: {{adminKey}}
Content-Type: application/json

{
  "subastaId": {{subastaPublicableId}},
  "catalogoId": {{catalogoPublicableId}}
}

### 14 - Consignacion - Detalle final
GET {{baseUrl}}/api/consignaciones/{{newConsignacionId}}
Authorization: Bearer {{accessConsignador}}

### 15 - Consignacion - Filtro activas
GET {{baseUrl}}/api/consignaciones?filtro=activas&page=0&size=20
Authorization: Bearer {{accessConsignador}}
